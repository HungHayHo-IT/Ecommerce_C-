@{
    ViewBag.Title = "Chi tiết đơn hàng";
}

<div class="box box-primary">
    <div class="box-header with-border">
        <h3 class="box-title">Thông tin đơn hàng</h3>
        <div class="box-tools pull-right">
            <a href="~/Order/Edit/1" class="btn btn-primary btn-sm"><i class="fa fa-edit"></i> Sửa thông tin</a>
            <a href="~/Order/Accept/1" class="btn btn-success btn-sm" onclick="return confirm('Xác nhận duyệt đơn hàng này?')"><i class="fa fa-check"></i> Duyệt đơn</a>
            <a href="~/Order/Finish/1" class="btn btn-warning btn-sm" onclick="return confirm('Xác nhận đơn hàng đã hoàn tất thành công?')"><i class="fa fa-check-circle"></i> Hoàn tất</a>
            <a href="~/Order/Cancel/1" class="btn btn-danger btn-sm" onclick="return confirm('Xác nhận hủy đơn hàng này?')"><i class="fa fa-times"></i> Hủy đơn</a>
            <a href="~/Order/Reject/1" class="btn btn-danger btn-sm" onclick="return confirm('Xác nhận từ chối đơn hàng này?')"><i class="fa fa-ban"></i> Từ chối</a>
            <a href="~/Order/Delete/1" class="btn btn-danger btn-sm" onclick="return confirm('Có chắc chắn muốn xóa đơn hàng này không?')"><i class="fa fa-trash"></i> Xóa</a>
            <a href="~/Order" class="btn btn-default btn-sm"><i class="fa fa-arrow-left"></i> Quay lại</a>
        </div>
    </div>
    <div class="box-body">
        <div class="row">
            <div class="col-md-4">
                <h4 class="text-info">Thông tin chung</h4>
                <div class="form-group">
                    <label>Mã đơn hàng:</label>
                    <p class="form-control-static">1024</p>
                </div>
                <div class="form-group">
                    <label>Ngày lập:</label>
                    <p class="form-control-static">07/02/2026 08:30</p>
                </div>
                <div class="form-group">
                    <label>Nhân viên phụ trách:</label>
                    <p class="form-control-static">Administrator</p>
                </div>
                <div class="form-group">
                    <label>Trạng thái:</label>
                    <p class="form-control-static"><span class="label label-warning">Đang giao hàng</span></p>
                </div>
            </div>

            <div class="col-md-4">
                <h4 class="text-info">Thông tin khách hàng</h4>
                <div class="form-group">
                    <label>Tên khách hàng:</label>
                    <p class="form-control-static">Nguyễn Văn A</p>
                </div>
                <div class="form-group">
                    <label>Địa chỉ giao hàng:</label>
                    <p class="form-control-static">77 Nguyễn Huệ, TP Huế</p>
                </div>
                <div class="form-group">
                    <label>Tỉnh/Thành:</label>
                    <p class="form-control-static">Thừa Thiên Huế</p>
                </div>
                <div class="form-group">
                    <label>Email / SĐT:</label>
                    <p class="form-control-static">email@example.com / 0905123456</p>
                </div>
            </div>

            <div class="col-md-4">
                <h4 class="text-info">Thông tin giao hàng</h4>
                <div class="form-group">
                    <label>Người giao hàng:</label>
                    <p class="form-control-static">Viettel Post</p>
                </div>
                <div class="form-group">
                    <label>Điện thoại Shipper:</label>
                    <p class="form-control-static">0987654321</p>
                </div>
                <div class="form-group">
                    <label>Thời điểm giao:</label>
                    <p class="form-control-static">08/02/2026 14:00</p>
                </div>
            </div>
        </div>

        <h4 class="text-info" style="margin-top: 20px;">Danh sách mặt hàng</h4>
        <div class="table-responsive">
            <table class="table table-bordered table-striped">
                <thead>
                    <tr class="bg-gray">
                        <th class="text-center">STT</th>
                        <th>Tên hàng</th>
                        <th class="text-center">ĐVT</th>
                        <th class="text-right">Số lượng</th>
                        <th class="text-right">Giá bán</th>
                        <th class="text-right">Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="text-center">1</td>
                        <td>Sữa bột Vinamilk</td>
                        <td class="text-center">Hộp</td>
                        <td class="text-right">2</td>
                        <td class="text-right">250.000</td>
                        <td class="text-right">500.000</td>
                    </tr>
                    <tr>
                        <td class="text-center">2</td>
                        <td>Bia Huda</td>
                        <td class="text-center">Thùng</td>
                        <td class="text-right">1</td>
                        <td class="text-right">230.000</td>
                        <td class="text-right">230.000</td>
                    </tr>
                </tbody>
                <tfoot>
                    <tr>
                        <th colspan="5" class="text-right">Tổng cộng:</th>
                        <th class="text-right text-danger text-bold">730.000</th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>