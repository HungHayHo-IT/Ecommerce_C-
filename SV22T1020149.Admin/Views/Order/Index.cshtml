@model OrderSearchInput
@{
    ViewBag.Title = "Quản lý Đơn hàng";
}
@section PageToolBar {
    <a href="~/Order/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Lập đơn hàng mới
    </a>
}
<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch"
              method="get"
              action="~/Order/Search"
              data-target="searchResult"
              onsubmit="paginationSearch(event, this, 1)">
            <input type="hidden" asp-for="PageSize" />

            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label">Trạng thái đơn hàng</label>
                    <select asp-for="Status" class="form-select">
                        <option value="0">-- Tất cả --</option>
                        <option value="@((int)OrderStatusEnum.New)">@OrderStatusEnum.New.GetDescription()</option>
                        <option value="@((int)OrderStatusEnum.Accepted)">@OrderStatusEnum.Accepted.GetDescription()</option>
                        <option value="@((int)OrderStatusEnum.Shipping)">@OrderStatusEnum.Shipping.GetDescription()</option>
                        <option value="@((int)OrderStatusEnum.Completed)">@OrderStatusEnum.Completed.GetDescription()</option>
                        <option value="@((int)OrderStatusEnum.Cancelled)">@OrderStatusEnum.Cancelled.GetDescription()</option>
                        <option value="@((int)OrderStatusEnum.Rejected)">@OrderStatusEnum.Rejected.GetDescription()</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Thời gian lập đơn hàng</label>
                    <div class="input-group">
                        <input type="date" asp-for="DateFrom" class="form-control" />
                        <span class="input-group-text">-</span>
                        <input type="date" asp-for="DateTo" class="form-control" />
                    </div>
                </div>

                <div class="col-md-5">
                    <label class="form-label">Tên khách hàng</label>
                    <div class="input-group">
                        <input type="text"
                               asp-for="SearchValue"
                               class="form-control"
                               placeholder="Tên khách hàng..." autofocus />

                        <button type="submit" class="btn btn-info d-flex align-items-center">
                            <i class="bi bi-search me-1"></i>
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div id="searchResult">
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            paginationSearch(null, document.getElementById("formSearch"), @Model.Page);
        });
    </script>
}
