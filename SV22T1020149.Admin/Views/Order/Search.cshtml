@model PagedResult<OrderViewInfo>
@{
    Layout = null;
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> đơn hàng
</div>

<div class="card">
    <div class="card-body p-1">
        @if (Model.DataItems.Count == 0)
        {
            <div class="p-4 text-center text-muted">Không có đơn hàng nào phù hợp điều kiện tìm kiếm.</div>
        }
        else
        {
            <table class="table table-bordered table-hover mb-0 align-middle">
                <thead class="table-secondary">
                    <tr>
                        <th>Ngày đặt hàng</th>
                        <th>Tên khách hàng</th>
                        <th>Điện thoại</th>
                        <th>Ngày duyệt</th>
                        <th>Nhân viên xử lý</th>
                        <th class="text-end">Tổng tiền</th>
                        <th class="text-center" style="width:140px;">Trạng thái</th>
                        <th class="text-center" style="width:40px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.DataItems)
                    {
                        var badgeClass = item.Status switch
                        {
                            OrderStatusEnum.New => "bg-warning text-dark",
                            OrderStatusEnum.Accepted => "bg-info",
                            OrderStatusEnum.Shipping => "bg-primary",
                            OrderStatusEnum.Completed => "bg-success",
                            OrderStatusEnum.Cancelled or OrderStatusEnum.Rejected => "bg-danger",
                            _ => "bg-secondary"
                        };
                        <tr>
                            <td>@item.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@(string.IsNullOrWhiteSpace(item.CustomerName) ? "—" : item.CustomerName)</td>
                            <td>@(string.IsNullOrWhiteSpace(item.CustomerPhone) ? "—" : item.CustomerPhone)</td>
                            <td>@(item.AcceptTime?.ToString("dd/MM/yyyy HH:mm") ?? "—")</td>
                            <td>@(string.IsNullOrWhiteSpace(item.EmployeeName) ? "—" : item.EmployeeName)</td>
                            <td class="text-end">@item.TotalAmount.ToString("N0")</td>
                            <td class="text-center">
                                <span class="badge @badgeClass">@item.Status.GetDescription()</span>
                            </td>
                            <td class="text-center text-nowrap">
                                <a href="~/Order/Detail/@item.OrderID" class="btn btn-sm btn-primary" title="Chi tiết">
                                    <i class="bi bi-receipt"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @if (Model.PageCount > 1)
    {
        <div class="card-footer">
            <ul class="pagination justify-content-center mb-0">
                @foreach (var p in Model.GetDisplayPages())
                {
                    if (p.IsCurrent)
                    {
                        <li class="page-item active">
                            <a class="page-link">@p.Page</a>
                        </li>
                    }
                    else if (p.IsEllipsis)
                    {
                        <li class="page-item">
                            <a class="page-link">...</a>
                        </li>
                    }
                    else
                    {
                        <li class="page-item">
                            <a class="page-link" href="javascript:;"
                               onclick="paginationSearch(event, document.getElementById('formSearch'), @p.Page)">
                                @p.Page
                            </a>
                        </li>
                    }
                }
            </ul>
        </div>
    }
</div>
