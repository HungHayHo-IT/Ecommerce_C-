@model ProductSearchInput
@{
    ViewBag.Title = "Lập đơn hàng";
    var customers = ViewBag.Customers as IEnumerable<Customer> ?? Array.Empty<Customer>();
    var provinces = ViewBag.Provinces as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>
        ?? Array.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
}

<div class="row">
    <!-- Tìm kiếm & chọn mặt hàng -->
    <div class="col-4">
        <div class="card card-outline card-primary h-100">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-search"></i>
                    Lựa chọn hàng cần bán
                </h5>
            </div>

            <div class="card-body">
                <form id="formSearch"
                      method="get"
                      action="~/Order/SearchProduct"
                      data-target="searchResult"
                      onsubmit="paginationSearch(event, this, 1)">
                    <input type="hidden" asp-for="PageSize" />

                    <div class="input-group">
                        <input type="text" asp-for="SearchValue"
                               class="form-control"
                               placeholder="Nhập tên mặt hàng..." autofocus />
                        <button type="submit" class="btn btn-info d-flex align-items-center">
                            <i class="bi bi-search me-1"></i>
                        </button>
                    </div>
                </form>

                <div id="searchResult" class="mt-3">
                </div>
            </div>
        </div>
    </div>

    <!-- Giỏ hàng và thông tin khách hàng -->
    <div class="col-8">
        <div class="row">
            <div class="col-12" id="cart">
            </div>
        </div>
        <div class="row mt-3">
            <div class="col-12">
                <div class="card card-outline card-info">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-person"></i>
                            Thông tin khách hàng & nơi giao hàng
                        </h5>
                    </div>

                    <div class="card-body">
                        <form method="post" onsubmit="createOrder(event,this)">
                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Khách hàng</label>
                                <div class="col-md-10">
                                    <select name="customerID" class="form-select">
                                        <option value="0">-- Khách lẻ / không chọn --</option>
                                        @foreach (var c in customers)
                                        {
                                            <option value="@c.CustomerID">@c.CustomerName</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Tỉnh/thành</label>
                                <div class="col-md-10">
                                    <select name="province" class="form-select">
                                        @foreach (var p in provinces)
                                        {
                                            <option value="@p.Value">@p.Text</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Địa chỉ</label>
                                <div class="col-md-10">
                                    <textarea name="address" class="form-control" rows="2" placeholder="Địa chỉ giao hàng..."></textarea>
                                </div>
                            </div>

                            <div class="text-end">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-check-circle"></i>
                                    Lập đơn hàng
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            paginationSearch(null, document.getElementById("formSearch"), @Model.Page);
            showCart();
        });

        function showCart() {
            fetch('/Order/ShowCart', {
                method: 'GET',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Không thể tải dữ liệu giỏ hàng');
                }
                return response.text();
            })
            .then(html => {
                const cartElement = document.getElementById('cart');
                if (cartElement) {
                    cartElement.innerHTML = html;
                }
            })
            .catch(error => {
                console.error('Lỗi khi gọi showCart:', error);
                const cartElement = document.getElementById('cart');
                if (cartElement) {
                    cartElement.innerHTML = '<div class="text-danger">Có lỗi xảy ra khi tải giỏ hàng.</div>';
                }
            });
        }

 function clearCart() {
            if (!confirm("Bạn có chắc chắn muốn xóa toàn bộ giỏ hàng không?")) {
                return;
            }

            fetch('/Order/ClearCart', {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Không thể kết nối đến máy chủ để làm sạch giỏ hàng.');
                }
                return response.json();
            })
            .then(data => {
                if (data.code !== 0) {
                    if (typeof showCart === "function") {
                        showCart();
                    }
                } else {
                    alert("Lỗi: " + data.message);
                }
            })
            .catch(error => {
                console.error('Lỗi khi gọi clearCart:', error);
                alert('Có lỗi xảy ra khi làm sạch giỏ hàng.');
            });
        }

        function deleteCartItem(productID) {
            fetch(`/Order/DeleteCartItem?productId=${encodeURIComponent(productID)}`, {
                method: 'POST'
            })
            .then(response => response.json())
            .then(result => {
                showCart();
            })
            .catch(error => {
                console.error('Lỗi khi xóa sản phẩm khỏi giỏ hàng:', error);
                alert('Có lỗi xảy ra khi xóa sản phẩm.');
            });
        }

        function createOrder(event, form) {
            if (event) {
                event.preventDefault();
            }

            const formData = new FormData(form);

            fetch('/Order/CreateOrder', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(result => {
                if (result.code === 0) {
                    alert(result.message);
                } else {
                    window.location.href = `/Order/Detail/${result.code}`;
                }
            })
            .catch(error => {
                console.error('Lỗi khi tạo đơn hàng:', error);
                alert('Có lỗi xảy ra khi tạo đơn hàng.');
            });
        }

        function updateCartItem(event, form) {
            if (event) {
                event.preventDefault();
            }

            const formData = new FormData(form);

            fetch('/Order/UpdateCartItem', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(result => {
                if (result.code === 0) {
                    alert(result.message);
                } else {
                    const modalElement = document.getElementById('dialogModal');
                    const modalInstance = bootstrap.Modal.getInstance(modalElement)
                        || new bootstrap.Modal(modalElement);

                    modalInstance.hide();

                    showCart();
                }
            })
            .catch(error => {
                console.error('Lỗi khi cập nhật giỏ hàng:', error);
                alert('Có lỗi xảy ra khi cập nhật sản phẩm.');
            });
        }

        function addCartItem(event, form) {
            event.preventDefault();
            const url = form.getAttribute('action') || '/Order/AddCartItem';

            const formData = new FormData(form);

            fetch(url, {
                method: 'POST',
                body: formData,
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Mất kết nối với máy chủ');
                }
                return response.json();
            })
            .then(data => {
                if (data.code === 0) {
                    alert("Lỗi: " + data.message);
                } else {
                    if (typeof showCart === "function") {
                        showCart();
                    }
                }
            })
            .catch(error => {
                console.error('Lỗi khi gọi addCartItem:', error);
                alert('Có lỗi xảy ra, vui lòng thử lại sau.');
            });

            return false;
        }
    </script>
}
