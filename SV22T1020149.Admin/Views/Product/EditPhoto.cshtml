@model ProductPhoto
@{
    ViewBag.Title = Model.PhotoID == 0 ? "Thêm ảnh cho mặt hàng" : "Thay đổi ảnh mặt hàng";
}

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu thông tin
    </button>

    @* Quay lại trang edit sản phẩm và nhảy đến tab photos *@
    <a href="~/Product/Edit/@Model.ProductID#photos" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card card-outline card-info shadow-sm">
            <div class="card-header">
                <h5 class="mb-0 fw-bold text-info">
                    <i class="bi bi-image me-2"></i>@ViewBag.Title
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" action="~/Product/SavePhoto" method="post" enctype="multipart/form-data">
                    @* Các trường ẩn bắt buộc *@
                    <input type="hidden" name="PhotoID" value="@Model.PhotoID" />
                    <input type="hidden" name="ProductID" value="@Model.ProductID" />
                    <input type="hidden" name="Photo" value="@Model.Photo" />

                    <div class="row mb-3 align-items-center">
                        <label class="col-sm-3 fw-semibold">Chọn ảnh</label>
                        <div class="col-sm-9">
                            <input type="file"
                                   name="uploadPhoto"
                                   class="form-control"
                                   accept="image/*"
                                   onchange="document.getElementById('imgPreview').src = window.URL.createObjectURL(this.files[0])" />
                            <div class="form-text italic small">Chọn file ảnh để thay đổi (định dạng .jpg, .png, .gif)</div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Xem trước</label>
                        <div class="col-sm-9">
                            @{
                                string photoUrl = Url.Content("~/images/products/nophoto.png");
                                if (!string.IsNullOrEmpty(Model.Photo))
                                {
                                    photoUrl = Url.Content($"~/images/products/{Model.Photo}");
                                }
                            }
                            <img id="imgPreview"
                                 src="@photoUrl"
                                 class="img-thumbnail shadow-sm"
                                 style="max-height:250px; min-width:150px; object-fit:contain;"
                                 onerror="this.src='@Url.Content("~/images/products/nophoto.png")'" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Mô tả ảnh</label>
                        <div class="col-sm-9">
                            <input type="text" name="Description"
                                   class="form-control"
                                   placeholder="Ví dụ: Mặt trước, Mặt nghiêng, Ảnh hộp..."
                                   value="@Model.Description"
                                   required />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Thứ tự hiển thị</label>
                        <div class="col-sm-3">
                            <input type="number"
                                   name="DisplayOrder"
                                   class="form-control"
                                   value="@Model.DisplayOrder"
                                   min="1" />
                        </div>
                    </div>

                    <div class="row mb-4">
                        <label class="col-sm-3 fw-semibold">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check form-switch mt-1">
                                <input class="form-check-input"
                                       type="checkbox"
                                       name="IsHidden"
                                       id="IsHidden"
                                       value="true"
                                       @(Model.IsHidden ? "checked" : "") />
                                <input type="hidden" name="IsHidden" value="false" />
                                <label class="form-check-label text-muted" for="IsHidden">
                                    Ẩn ảnh này khỏi trang bán hàng
                                </label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .italic {
        font-style: italic;
    }

    .card-outline.card-info {
        border-top: 3px solid #0dcaf0;
    }
</style>