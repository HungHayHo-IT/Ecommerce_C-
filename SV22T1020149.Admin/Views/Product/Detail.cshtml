@model Product
@using SV22T1020149.BusinessLayers
@{
    ViewBag.Title = "Chi tiết mặt hàng";
}

<div class="container-fluid pt-3">
    @* --- THÔNG TIN CHÍNH --- *@
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
            <h5 class="mb-0 fw-bold text-primary"><i class="bi bi-info-circle me-2"></i>Thông tin mặt hàng</h5>
            <div>
                <a href="~/Product/Edit/@Model.ProductID" class="btn btn-sm btn-primary"><i class="bi bi-pencil-square"></i> Chỉnh sửa chính</a>
                <a href="~/Product" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
            </div>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-3 text-center border-end">
                    @{
                        string photoUrl = Url.Content("~/images/products/demo.png");
                        if (!string.IsNullOrEmpty(Model.Photo))
                        {
                            photoUrl = Model.Photo.StartsWith("data:image") ? Model.Photo : Url.Content($"~/images/products/{Model.Photo}");
                        }
                    }
                    <img src="@photoUrl" class="img-fluid rounded shadow-sm border" alt="@Model.ProductName"
                         onerror="this.src='@Url.Content("~/images/products/demo.png")'" />
                </div>
                <div class="col-md-9 ps-md-4">
                    <h3 class="fw-bold mb-3 text-dark">@Model.ProductName</h3>
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <p class="mb-1 text-muted small text-uppercase fw-bold">Loại hàng</p>
                            <p class="fs-6">@((await CatalogDataService.GetCategoryAsync(Model.CategoryID ?? 0))?.CategoryName ?? "N/A")</p>
                        </div>
                        <div class="col-sm-6">
                            <p class="mb-1 text-muted small text-uppercase fw-bold">Nhà cung cấp</p>
                            <p class="fs-6">@((await PartnerDataService.GetSupplierAsync(Model.SupplierID ?? 0))?.SupplierName ?? "N/A")</p>
                        </div>
                        <div class="col-sm-4">
                            <p class="mb-1 text-muted small text-uppercase fw-bold">Đơn vị tính</p>
                            <p class="fs-6"><span class="badge bg-secondary">@Model.Unit</span></p>
                        </div>
                        <div class="col-sm-4">
                            <p class="mb-1 text-muted small text-uppercase fw-bold">Giá bán</p>
                            <p class="fs-6 text-danger fw-bold">@Model.Price.ToString("N0") đ</p>
                        </div>
                        <div class="col-sm-4">
                            <p class="mb-1 text-muted small text-uppercase fw-bold">Trạng thái</p>
                            @if (Model.IsSelling)
                            {
                                <span class="badge bg-success">Đang bán</span>
                            }
                            else
                            {

                                <span class="badge bg-danger">Ngừng bán</span>
                            }
                        </div>
                        <div class="col-sm-12">
                            <p class="mb-1 text-muted small text-uppercase fw-bold">Mô tả tóm tắt</p>
                            <p class="text-muted italic">@Model.ProductDescription</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        @* --- THƯ VIỆN ẢNH --- *@
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-images me-2 text-warning"></i>Thư viện ảnh</h6>
                    <a href="~/Product/Photo/@Model.ProductID?method=add" class="btn btn-xs btn-success"><i class="bi bi-plus-lg"></i> Thêm ảnh</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" style="font-size: 0.85rem;">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3" style="width:70px">Ảnh</th>
                                    <th>Mô tả / Thứ tự</th>
                                    <th class="text-center" style="width:100px">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in await CatalogDataService.ListPhotosAsync(Model.ProductID))
                                {
                                    <tr>
                                        <td class="ps-3">
                                            <img src="~/images/products/@(string.IsNullOrEmpty(p.Photo) ? "nophoto.png" : p.Photo)"
                                                 class="rounded border" style="width:50px; height:50px; object-fit:cover" />
                                        </td>
                                        <td>
                                            <div class="fw-bold">@p.Description</div>
                                            <small class="text-muted">Thứ tự: @p.DisplayOrder | Ẩn: @(p.IsHidden ? "Có" : "Không")</small>
                                        </td>
                                        <td class="text-center">
                                            <a href="~/Product/Photo/@Model.ProductID?method=edit&photoId=@p.PhotoID" class="btn btn-xs btn-outline-info"><i class="bi bi-pencil"></i></a>
                                            <a href="~/Product/Photo/@Model.ProductID?method=delete&photoId=@p.PhotoID" class="btn btn-xs btn-outline-danger" onclick="return confirm('Xóa ảnh này?')"><i class="bi bi-trash"></i></a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        @* --- THUỘC TÍNH --- *@
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-list-stars me-2 text-primary"></i>Thuộc tính mặt hàng</h6>
                    <a href="~/Product/Attribute/@Model.ProductID?method=add" class="btn btn-xs btn-success"><i class="bi bi-plus-lg"></i> Thêm thuộc tính</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" style="font-size: 0.85rem;">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3">Tên thuộc tính</th>
                                    <th>Giá trị</th>
                                    <th class="text-center" style="width:100px">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var a in await CatalogDataService.ListAttributesAsync(Model.ProductID))
                                {
                                    <tr>
                                        <td class="ps-3 fw-bold text-muted">@a.AttributeName</td>
                                        <td>@a.AttributeValue</td>
                                        <td class="text-center">
                                            <a href="~/Product/Attribute/@Model.ProductID?method=edit&attributeId=@a.AttributeID" class="btn btn-xs btn-outline-info"><i class="bi bi-pencil"></i></a>
                                            <a href="~/Product/Attribute/@Model.ProductID?method=delete&attributeId=@a.AttributeID" class="btn btn-xs btn-outline-danger" onclick="return confirm('Xóa thuộc tính này?')"><i class="bi bi-trash"></i></a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-xs {
        padding: 2px 6px;
        font-size: 0.75rem;
    }

    .card-header {
        border-bottom: 1px solid #f0f0f0 !important;
    }

    .table td {
        padding: 0.6rem 0.5rem !important;
    }

    .italic {
        font-style: italic;
    }
</style>