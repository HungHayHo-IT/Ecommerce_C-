@model ProductAttribute
@{
    ViewBag.Title = Model.AttributeID == 0 ? "Thêm thuộc tính mặt hàng" : "Chỉnh sửa thuộc tính mặt hàng";
}

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu thuộc tính
    </button>

    @* Quay lại tab attributes của trang Edit sản phẩm *@
    <a href="~/Product/Edit/@Model.ProductID#attributes" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card card-outline card-success shadow-sm">
            <div class="card-header">
                <h5 class="mb-0 fw-bold text-success">
                    <i class="bi bi-tag me-2"></i>@ViewBag.Title
                </h5>
            </div>

            <div class="card-body p-4">
                <form id="formEdit" action="~/Product/SaveAttribute" method="post">
                    @* Các trường ẩn để định danh *@
                    <input type="hidden" name="AttributeID" value="@Model.AttributeID" />
                    <input type="hidden" name="ProductID" value="@Model.ProductID" />

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold col-form-label">
                            Tên thuộc tính
                        </label>
                        <div class="col-sm-9">
                            <input type="text"
                                   name="AttributeName"
                                   value="@Model.AttributeName"
                                   class="form-control"
                                   placeholder="Ví dụ: Màu sắc, Kích thước, Chất liệu..."
                                   required autofocus />
                            <div class="form-text small italic">Ví dụ: RAM, CPU, Dung lượng Pin...</div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold col-form-label">
                            Giá trị thuộc tính
                        </label>
                        <div class="col-sm-9">
                            <input type="text"
                                   name="AttributeValue"
                                   value="@Model.AttributeValue"
                                   class="form-control"
                                   placeholder="Ví dụ: Đỏ, XL, 500g, 16GB..."
                                   required />
                            <div class="form-text small italic">Nhập nội dung chi tiết cho thuộc tính trên.</div>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <label class="col-sm-3 fw-semibold col-form-label">
                            Thứ tự hiển thị
                        </label>
                        <div class="col-sm-3">
                            <input type="number"
                                   name="DisplayOrder"
                                   class="form-control"
                                   value="@Model.DisplayOrder"
                                   min="1"
                                   required />
                        </div>
                    </div>
                </form>
            </div>

            @if (Model.AttributeID > 0)
            {
                <div class="card-footer bg-light text-center py-2">
                    <small class="text-muted">Đang chỉnh sửa thuộc tính mã số: <strong>#@Model.AttributeID</strong></small>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .italic {
        font-style: italic;
    }

    .card-outline.card-success {
        border-top: 3px solid #198754;
    }

    .col-form-label {
        padding-top: calc(.375rem + 1px);
    }
</style>