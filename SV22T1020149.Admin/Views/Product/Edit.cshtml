@model Product
@{
}

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i> Lưu dữ liệu
    </button>
    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-box-seam me-2"></i> Thông tin mặt hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" action="~/Product/SaveData" method="post" enctype="multipart/form-data">
                    @* Hidden fields *@
                    <input type="hidden" asp-for="ProductID" />
                    @* Lưu lại đường dẫn ảnh hiện tại (nếu có) để Controller lấy lại khi cập nhật *@
                    <input type="hidden" asp-for="Photo" />

                    <div class="row mb-3">
                        <label class="col-sm-2 col-form-label fw-bold">Tên mặt hàng</label>
                        <div class="col-sm-10">
                            <input type="text" asp-for="ProductName" class="form-control" placeholder="Nhập tên mặt hàng" autofocus />
                            <span asp-validation-for="ProductName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-2 col-form-label fw-bold">Loại hàng</label>
                        <div class="col-sm-4">
                            <select class="form-select" asp-for="CategoryID"
                                    asp-items="@(await SelectListHelper.Categories())">
                            </select>
                            <span asp-validation-for="CategoryID" class="text-danger"></span>
                        </div>
                        <label class="col-sm-2 col-form-label text-end fw-bold">Nhà cung cấp</label>
                        <div class="col-sm-4">
                            <select class="form-select" asp-for="SupplierID"
                                    asp-items="@(await SelectListHelper.Suppliers())">
                            </select>
                            <span asp-validation-for="SupplierID" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-2 col-form-label fw-bold">Đơn vị tính</label>
                        <div class="col-sm-4">
                            <input type="text" asp-for="Unit" class="form-control" placeholder="cái, hộp, kg..." />
                            <span asp-validation-for="Unit" class="text-danger"></span>
                        </div>
                        <label class="col-sm-2 col-form-label text-end fw-bold">Giá bán</label>
                        <div class="col-sm-4">
                            <input type="text" asp-for="Price" class="form-control money-input text-end"
                                   value="@Model.Price.ToString("N0")" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-2 col-form-label fw-bold">Mô tả</label>
                        <div class="col-sm-10">
                            <textarea asp-for="ProductDescription" class="form-control" rows="3"></textarea>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-2 col-form-label fw-bold">Ảnh sản phẩm</label>
                        <div class="col-sm-10">
                            @* THÊM name="uploadPhoto" ĐỂ GỬI FILE VẬT LÝ LÊN SERVER *@
                            <input type="file" id="filePicker" name="uploadPhoto" class="form-control" accept="image/*" onchange="previewImage()" />

                            <div class="mt-2">
                                <img id="imgPreview"
                                     src="@(string.IsNullOrEmpty(Model.Photo) ? Url.Content("~/images/products/nophoto.png") : Url.Content($"~/{Model.Photo}"))"
                                     class="img-thumbnail"
                                     style="max-height: 200px;" />
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-10 offset-sm-2">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" asp-for="IsSelling" id="IsWorking" />
                                <label class="form-check-label fw-bold" for="IsWorking">Mặt hàng này hiện đang được rao bán</label>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-10 offset-sm-2">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@if (Model.ProductID > 0)
{
    <div id="photos" class="mt-4">
        @await Html.PartialAsync("ListPhotos", Model.ProductID)
    </div>

    <div id="attributes" class="mt-4">
        @await Html.PartialAsync("ListAttributes", Model.ProductID)
    </div>
}

@* Script xử lý hiển thị ảnh xem trước (Preview) *@
<script>
    function previewImage() {
        var file = document.getElementById('filePicker').files[0];
        if (file) {
            var reader = new FileReader();
            reader.onloadend = function() {
                // Chỉ gán vào thẻ <img> để hiển thị hình ảnh tạm thời
                document.getElementById('imgPreview').src = reader.result;
            }
            reader.readAsDataURL(file);
        }
    }
</script>