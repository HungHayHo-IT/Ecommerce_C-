@{
    ViewBag.Title = "Quản lý ảnh của mặt hàng";
    // Giả sử Model là List<ProductPhoto>
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
<div class="box box-info">
    <div class="box-header with-border">
        <h3 class="box-title">Danh sách ảnh phụ</h3>
        <div class="box-tools pull-right">
            <a href="~/Product/CreatePhoto/@ViewContext.RouteData.Values["id"]" class="btn btn-primary btn-sm">
                <i class="fa fa-plus"></i> Bổ sung ảnh
            </a>
            <button type="button" class="btn btn-box-tool" data-widget="collapse" data-toggle="tooltip" title="Collapse">
                <i class="fa fa-minus"></i>
            </button>
        </div>
    </div>

    <div class="box-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover table-striped">
                <thead>
                    <tr class="bg-gray">
                        <th class="text-center" style="width: 100px;">Ảnh</th>
                        <th>Mô tả / Tiêu đề</th>
                        <th class="text-center" style="width: 100px;">Thứ tự</th>
                        <th class="text-center" style="width: 100px;">Ẩn ảnh</th>
                        <th class="text-center" style="width: 100px;">Chức năng</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="text-center" style="vertical-align: middle;">
                            <img src="~/lib/adminlte/assets/img/prod-2.jpg" style="width: 80px;" alt="" />
                        </td>
                        <td style="vertical-align: middle;">Ảnh mặt trước</td>
                        <td class="text-center" style="vertical-align: middle;">1</td>
                        <td class="text-center" style="vertical-align: middle;">
                            <i class="fa fa-check-square-o text-danger"></i>
                        </td>
                        <td class="text-center" style="vertical-align: middle;">
                            <a href="~/Product/EditPhoto/@ViewContext.RouteData.Values["id"]?photoId=10" class="btn btn-xs btn-primary">
                                <i class="fa fa-edit"></i>
                            </a>
                            <a href="~/Product/DeletePhoto/@ViewContext.RouteData.Values["id"]?photoId=10" class="btn btn-xs btn-danger" onclick="return confirm('Xóa ảnh này?')">
                                <i class="fa fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                    <tr>
                        <td class="text-center" style="vertical-align: middle;">
                            <img src="~/lib/adminlte/assets/img/prod-3.jpg" style="width: 80px;" alt="" />
                        </td>
                        <td style="vertical-align: middle;">Ảnh mặt sau</td>
                        <td class="text-center" style="vertical-align: middle;">2</td>
                        <td class="text-center" style="vertical-align: middle;"></td>
                        <td class="text-center" style="vertical-align: middle;">
                            <a href="~/Product/EditPhoto/@ViewContext.RouteData.Values["id"]?photoId=11" class="btn btn-xs btn-primary">
                                <i class="fa fa-edit"></i>
                            </a>
                            <a href="~/Product/DeletePhoto/@ViewContext.RouteData.Values["id"]?photoId=11" class="btn btn-xs btn-danger" onclick="return confirm('Xóa ảnh này?')">
                                <i class="fa fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="box-footer text-center">
        <a href="~/Product" class="btn btn-default">
            <i class="fa fa-arrow-left"></i> Quay lại danh sách mặt hàng
        </a>
    </div>
</div>