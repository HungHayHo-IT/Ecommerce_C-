@model int
@{
    Layout = null;
    // Lấy danh sách thuộc tính thật từ Database thông qua Service
    var attributes = await SV22T1020149.BusinessLayers.CatalogDataService.ListAttributesAsync(Model);
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-info card-outline mt-4">
            <div class="card-header">
                <div class="row">
                    <div class="col">
                        <h6 id="attributes" class="mb-0">
                            <i class="bi bi-list-task me-2"></i> Thuộc tính mặt hàng
                        </h6>
                    </div>
                    <div class="col text-end">
                        <a class="btn btn-sm btn-primary" href="~/Product/Attribute/@Model?method=add">
                            <i class="bi bi-plus-circle me-1"></i> Thêm thuộc tính
                        </a>
                    </div>
                </div>
            </div>

            <div class="card-body p-1">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th>Tên thuộc tính</th>
                            <th>Giá trị</th>
                            <th style="width:120px" class="text-center">Thứ tự</th>
                            <th style="width:100px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (attributes.Count() > 0)
                        {
                            foreach (var item in attributes)
                            {
                                <tr>
                                    <td>@item.AttributeName</td>
                                    <td>@item.AttributeValue</td>
                                    <td class="text-center">@item.DisplayOrder</td>
                                    <td class="text-center text-nowrap">
                                        <a class="btn btn-sm btn-primary" href="~/Product/Attribute/@item.ProductID?method=edit&attributeId=@item.AttributeID">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a class="btn btn-sm btn-danger" href="~/Product/Attribute/@item.ProductID?method=delete&attributeId=@item.AttributeID"
                                           onclick="return confirm('Xóa thuộc tính này của mặt hàng?')">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted">Mặt hàng này chưa có thuộc tính nào.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>