@model SV22T1020149.Models.Catalog.ProductPhoto

@{
    // Tiêu đề thay đổi tùy theo việc đang thêm mới hay cập nhật
    ViewBag.Title = Model.PhotoID == 0 ? "Bổ sung ảnh cho mặt hàng" : "Cập nhật ảnh mặt hàng";
}

<div class="box box-primary">
    <div class="box-header with-border">
        <h3 class="box-title">@ViewBag.Title: @ViewBag.ProductName</h3>
    </div>

    <div class="box-body">
        <form action="~/Product/SavePhoto" method="post" enctype="multipart/form-data">

            <input type="hidden" name="ProductID" value="@Model.ProductID" />
            <input type="hidden" name="PhotoID" value="@Model.PhotoID" />
            <input type="hidden" name="Photo" value="@Model.Photo" />

            <div class="form-group">
                <label>Chọn file ảnh:</label>
                <input type="file" class="form-control" name="uploadPhoto" accept="image/*"
                       onchange="document.getElementById('Photo-preview').src = window.URL.createObjectURL(this.files[0])" />
            </div>

            <div class="form-group">
                <label>Ảnh hiện tại:</label>
                <div>
                    <img id="Photo-preview"
                         src="~/@(string.IsNullOrWhiteSpace(Model.Photo) ? "images/products/nophoto.png" : Model.Photo)"
                         alt="Photo"
                         class="img-responsive img-bordered"
                         style="width:200px; object-fit:cover;" />
                </div>
            </div>

            <div class="form-group">
                <label>Mô tả ảnh:</label>
                <input type="text" class="form-control" name="Description" value="@Model.Description" placeholder="Nhập mô tả cho ảnh" />
            </div>

            <div class="form-group">
                <label>Thứ tự hiển thị:</label>
                <input type="number" class="form-control" name="DisplayOrder" value="@Model.DisplayOrder" min="1" />
            </div>

            <div class="form-group">
                <div class="checkbox">
                    <label>
                        <input type="checkbox" name="IsHidden" value="true" @(Model.IsHidden ? "checked" : "") />
                        Không hiển thị ảnh này
                    </label>
                    <input type="hidden" name="IsHidden" value="false" />
                </div>
            </div>

            <div class="form-group text-right">
                <button type="submit" class="btn btn-primary">
                    <i class="fa fa-save"></i> Lưu dữ liệu
                </button>
                <a href="~/Product/Edit/@Model.ProductID" class="btn btn-default">
                    <i class="fa fa-arrow-left"></i> Quay lại
                </a>
            </div>

            @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        </form>
    </div>
</div>