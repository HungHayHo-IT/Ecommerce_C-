@model List<SV22T1020149.Models.Sales.OrderDetailViewInfo>
@{
    ViewData["Title"] = "Gi? hýng";
}

@if (Model.Count == 0)
{
    <div class="alert alert-info">Gi? hýng tr?ng</div>
}
else
{
    <table class="table">
        <thead>
            <tr><th>#</th><th>TÍn</th><th>S? l??ng</th><th>Gi·</th><th>Thýnh ti?n</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var it in Model)
            {
                <tr>
                    <td>@it.ProductID</td>
                    <td>@it.ProductName</td>
                    <td>@it.Quantity</td>
                    <td>@it.SalePrice.ToString("N0")</td>
                    <td>@it.TotalPrice.ToString("N0")</td>
                    <td><button class="btn btn-sm btn-danger" onclick="remove(@it.ProductID)">XÛa</button></td>
                </tr>
            }
        </tbody>
    </table>

    <div class="text-end">
        <a class="btn btn-primary" href="~/Order/History">??t hýng</a>
    </div>
}

@section Scripts {
    <script>
        function remove(id) {
            fetch('/Order/RemoveCartItem', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ productId: id }) })
                .then(r => r.json()).then(j => location.reload());
        }
    </script>
}
