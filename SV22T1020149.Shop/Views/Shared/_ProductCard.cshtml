@model SV22T1020149.Models.Catalog.Product

<div class="card h-100 shadow-sm border-0 product-card transition-hover">
    <a href="~/Product/Detail/@Model.ProductID" class="overflow-hidden">
        <img src="@(string.IsNullOrEmpty(Model.Photo) ? "/images/products/nophoto.png" : $"/images/products/{Model.Photo}")"
             class="card-img-top img-fluid"
             alt="@Model.ProductName"
             style="height: 250px; object-fit: cover; transition: transform 0.3s ease;">
    </a>

    <div class="card-body d-flex flex-column text-center pb-2">
        <h6 class="card-title text-truncate mb-2">
            <a href="~/Product/Detail/@Model.ProductID" class="text-dark text-decoration-none" title="@Model.ProductName">
                @Model.ProductName
            </a>
        </h6>

        <div class="mt-auto">
            <span class="text-danger font-weight-bold h5">
                @Model.Price.ToString("N0") đ
            </span>
        </div>
    </div>

    <div class="card-footer bg-white border-0 text-center pb-3 pt-0">
        <a href="~/Product/Detail/@Model.ProductID" class="btn btn-outline-primary btn-sm w-100 rounded-pill font-weight-bold">
            <i class="fa fa-eye"></i> Xem chi tiết
        </a>
    </div>
</div>

<style>
    /* Hiệu ứng zoom ảnh khi trỏ chuột */
    .product-card:hover img {
        transform: scale(1.05);
    }
</style>