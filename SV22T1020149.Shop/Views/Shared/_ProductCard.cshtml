@model SV22T1020149.Models.Catalog.Product

<div class="card h-100 shadow-sm">
    <img src="~/images/products/@(Model.Photo ?? "nophoto.png")" class="card-img-top" style="height:180px;object-fit:cover;" />
    <div class="card-body d-flex flex-column">
        <h6 class="card-title">@Model.ProductName</h6>
        <p class="text-muted small mb-2">@Model.Unit</p>
        <div class="mt-auto d-flex justify-content-between align-items-center">
            <div class="fw-bold text-primary">@Model.Price.ToString("N0")</div>
            <a class="btn btn-sm btn-outline-primary" href="~/Product/Detail/@Model.ProductID">Xem</a>
        </div>
    </div>
</div>