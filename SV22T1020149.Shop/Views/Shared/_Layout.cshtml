<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SV22T1020149.Shop</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SV22T1020149.Shop.styles.css" asp-append-version="true" />
</head>
<body>
    @await Html.PartialAsync("_Header")

    <main role="main" class="pb-3" style="min-height: 70vh;">
        @if (TempData["Message"] is string msg && !string.IsNullOrEmpty(msg))
        {
            <div class="container">
                <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
                    @msg
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }

        @RenderBody()
    </main>

    @await Html.PartialAsync("_Footer")

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            fetch('/Order/CartCount')
                .then(r => r.json())
                .then(d => {
                    var el = document.getElementById('cartCount');
                    if (el) el.innerText = d.count || 0;
                });
        });

        document.addEventListener("DOMContentLoaded", function() {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            })
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)

    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.32/dist/sweetalert2.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.32/dist/sweetalert2.all.min.js"></script>

    <script>
        // Cấu hình Toast thông báo nhỏ góc trên bên phải
        const Toast = Swal.mixin({
            toast: true,
            position: 'top-end',
            showConfirmButton: false,
            timer: 2500,
            timerProgressBar: true,
            didOpen: (toast) => {
                toast.addEventListener('mouseenter', Swal.stopTimer)
                toast.addEventListener('mouseleave', Swal.resumeTimer)
            }
        });

        // Hàm Thêm vào giỏ gọi từ bất kỳ đâu
        function addProductToCart(productId, price) {
            $.ajax({
                url: '/Order/AddCartItem', // Gọi tới hàm AddCartItem trong OrderController
                type: 'POST',
                data: {
                    productId: productId,
                    quantity: 1, // Mặc định thêm 1 sản phẩm
                    price: price
                },
                success: function (res) {
                    if (res.code === 1) {
                        // Hiện thông báo Đẹp
                        Toast.fire({
                            icon: 'success',
                            title: 'Đã thêm sản phẩm vào giỏ hàng!'
                        });

                        // Tự động cập nhật số lượng trên Icon Giỏ hàng (Header)
                        updateCartBadge();
                    } else {
                        Toast.fire({
                            icon: 'error',
                            title: res.message || 'Không thể thêm vào giỏ hàng'
                        });
                    }
                },
                error: function () {
                    Toast.fire({
                        icon: 'error',
                        title: 'Lỗi kết nối đến máy chủ!'
                    });
                }
            });
        }

        // Hàm cập nhật số lượng ở Header
        function updateCartBadge() {
            $.ajax({
                url: '/Order/CartCount', // Gọi hàm đếm số lượng có sẵn trong Controller
                type: 'GET',
                success: function(res) {
                    if(res.count !== undefined) {
                        // Sửa id/class này cho khớp với thẻ số lượng giỏ hàng trên Navbar của bạn
                        $('.cart-badge, #cart-badge').text(res.count);
                    }
                }
            });
        }
    </script>
</body>
</html>
