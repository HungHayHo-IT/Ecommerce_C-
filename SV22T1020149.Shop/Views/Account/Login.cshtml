@{
    ViewData["Title"] = "??ng nh?p";
}
<style>
    .login-card { max-width:420px; margin:40px auto; background:#fff; padding:28px; border-radius:14px; box-shadow:0 12px 30px rgba(16,24,40,0.08); }
    .login-card h3{ margin-bottom:8px }
    .login-sub{ color:#6b7280; font-size:0.95rem; margin-bottom:18px }
    .form-control{ padding:12px 14px; border-radius:10px; border:1px solid #e6e9ef }
    .btn-login{ background:linear-gradient(90deg,#ff7a59,#ff6b4a); color:#fff; border:0; padding:12px; border-radius:28px; width:100%; font-weight:700 }
    .small-muted{ font-size:0.9rem; color:#9aa4b2 }
    .row-opts{ display:flex; justify-content:space-between; align-items:center; margin-top:8px }
    .show-pass{ background:transparent; border:0; color:#9aa4b2 }
</style>

<div class="login-card">
    <h3><i class="fas fa-sign-in-alt" style="color:#ff6b4a;margin-right:8px"></i> Đăng nhập</h3>
    <div class="login-sub">Chào mừng bạn trở lại! Vui lòng nhập thông tin tài khoản.</div>

    <form method="post" asp-action="Login">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">Đăng nhập thất bại</div>
        }
        <div class="mb-3">
            <label class="form-label">Email / Số điện thoại</label>
            <input name="email" class="form-control" placeholder="example@fashionhub.com hoặc 0912345678" />
        </div>
        <div class="mb-3">
            <label class="form-label">Mật khẩu</label>
            <div style="position:relative">
                <input name="password" type="password" class="form-control" id="pwdField" />
                <button type="button" class="show-pass" onclick="togglePwd()" style="position:absolute;right:10px;top:8px"><i id="pwdIcon" class="far fa-eye-slash"></i></button>
            </div>
        </div>

        <div class="row-opts">
            <label><input type="checkbox" name="remember" /> Ghi nhớ đăng nhập</label>
            <a href="#" class="small-muted">Quên mật khẩu?</a>
        </div>

        <div style="margin-top:18px">
            <button class="btn-login">Đăng nhập</button>
        </div>

        <div style="text-align:center; margin-top:14px" class="small-muted">Chưa có tài khoản? <a href="/Account/Register">Đăng ký ngay</a></div>
    </form>
</div>

<script>
    function togglePwd(){
        const f = document.getElementById('pwdField');
        const i = document.getElementById('pwdIcon');
        if(f.type === 'password'){ f.type='text'; i.classList.remove('fa-eye-slash'); i.classList.add('fa-eye'); }
        else { f.type='password'; i.classList.remove('fa-eye'); i.classList.add('fa-eye-slash'); }
    }
</script>
